{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run active file (WSL)",
      "type": "cppdbg",
      "request": "launch",
      "program": "/tmp/${fileBasenameNoExtension}",
      "args": [],
      "stopAtEntry": false,
      "cwd": "${fileDirname}",
      "environment": [],
      "externalConsole": false,
      "MIMode": "gdb",
      "miDebuggerPath": "/usr/bin/gdb",
      "preLaunchTask": "compile-active-file",
      "setupCommands": [
        {
          "text": "-enable-pretty-printing",
          
          "ignoreFailures": true
        }
      ]
    }
  ]
}
