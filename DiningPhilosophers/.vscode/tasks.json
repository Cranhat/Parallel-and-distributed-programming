{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "compile-active-file",
      "type": "shell",
      "command": "g++",
      "args": [
		"-DLOCAL",
        "-g",
        "${file}",
        "-o",
        "/tmp/${fileBasenameNoExtension}"
      ],
      "problemMatcher": ["$gcc"]
    }
  ]
}
